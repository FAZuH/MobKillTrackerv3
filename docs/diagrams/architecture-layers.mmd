graph LR
    subgraph Entry["Entry Point"]
        Main["Main<br>(ClientModInitializer)"]
    end

    subgraph Events["Event Layer"]
        ChatMixin["ChatHudMixin"]
        EH["EventHandler"]
        TotemEvent["TotemEvent"]
        CompletionEvent["CompletionEvent"]
        TerminationEvent["TerminationEvent"]
    end

    subgraph Core["Core / Tracking"]
        DH["DataHandler"]
        LH["DataHandler.ListenerHandler"]
        EEH["EntityEventHandler"]
    end

    subgraph Storage["Storage"]
        DM["DropManager"]
        DS["DropStatistics"]
    end

    subgraph Commands["Commands"]
        MKT["MKTCommand"]
        MKTD["MKTDebugCommand"]
    end

    subgraph Utils["Utilities"]
        IDB["ItemDatabase"]
        Config["Config"]
        Message["Message"]
    end

    Main -->|registers| EH
    Main -->|loads| Config
    Main -->|fetches| IDB
    Main -->|registers| MKT
    Main -->|registers| MKTD

    ChatMixin -->|intercepts chat| EH
    EH -->|creates| TotemEvent
    TotemEvent -->|triggers| DH
    EH -->|on disconnect terminates| LH
    EH -->|handles| CompletionEvent

    DH -->|owns| EEH
    DH -->|posts| CompletionEvent
    DH -.->|extends| LH
    LH -->|on termination| TerminationEvent

    EEH -->|queries| IDB
    EEH -->|updates| DS

    CompletionEvent -->|triggers insert| DM
    DM -->|stores| DS

    MKT -->|queries| DM
    MKT -->|outputs| Message
    MKTD -->|queries| DM
    MKTD -->|outputs| Message
